{
    "compilerOptions": {
        "composite": true,
        "tsBuildInfoFile": "./node_modules/.cache/tsconfig.app.tsbuildinfo",
        "target": "ES2020",
        "useDefineForClassFields": true,
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        /* Configuración de resolución de módulos */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "moduleDetection": "force",
        "noEmit": true,
        "jsx": "react-jsx", // <--- AGREGADO PARA SOPORTE JSX transform moderna
        /* Comprobaciones estrictas (Para que salte el error de string | string[]) */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true
    },
    "include": [
        "src"
    ] // Asegúrate de que incluya tu carpeta de código
}